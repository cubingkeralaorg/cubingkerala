generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Users {
  wcaid     String   @id @unique
  name      String
  avatarUrl String
  country   String?
  gender    String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Requests {
  wcaid     String   @id @unique
  name      String
  avatarUrl String
  country   String?
  gender    String?
  role      String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Members {
  wcaid     String   @id @unique
  name      String
  avatarUrl String
  country   String?
  gender    String?
  role      String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Competitions {
  id           String   @id @unique
  name         String
  city         String
  start_date   String
  end_date     String
  event_ids    String[]
  venue        String
  country_iso2 String
  has_results  Boolean  @default(false)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
  cancelled_at String?
}

model MemberWcaData {
  wcaid     String   @id @unique
  data      Json
  updatedAt DateTime @updatedAt
}
